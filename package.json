{
  "name": "@boltpay/react-native",
  "version": "0.8.1",
  "description": "Bolt React Native SDK",
  "license": "MIT",
  "main": "./lib/module/index.js",
  "types": "./lib/typescript/src/index.d.ts",
  "exports": {
    ".": {
      "react-native": "./src/index.ts",
      "source": "./src/index.ts",
      "types": "./lib/typescript/src/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./payments": {
      "react-native": "./src/payments/index.ts",
      "source": "./src/payments/index.ts",
      "types": "./lib/typescript/src/payments/index.d.ts",
      "default": "./lib/module/payments/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "lib",
    "src",
    "android",
    "ios",
    "cpp",
    "*.podspec",
    "react-native.config.js",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "example": "yarn workspace bolt-react-native-sdk-example",
    "clean": "del-cli android/build example/android/build example/android/app/build example/ios/build lib",
    "prepare": "node scripts/update-sdk-version.js && bob build",
    "typecheck": "tsc",
    "test": "jest",
    "release": "release-it",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "inject-telemetry-config": "node scripts/inject-telemetry-config.js",
    "gen-dev-telemetry-config": "node scripts/gen-dev-telemetry-config.js",
    "gen-bolt-config": "node scripts/gen-bolt-config.js"
  },
  "keywords": [
    "react-native",
    "ios",
    "android"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BoltApp/bolt-react-native-sdk.git"
  },
  "author": "BoltOwner <bolt@bolt.com> (https://www.bolt.com)",
  "bugs": {
    "url": "https://github.com/BoltApp/bolt-react-native-sdk/issues"
  },
  "homepage": "https://github.com/BoltApp/bolt-react-native-sdk#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^20.4.2",
    "@eslint/compat": "^2.0.2",
    "@eslint/eslintrc": "^3.3.4",
    "@eslint/js": "^9.0.0",
    "@react-native/babel-preset": "0.85.0",
    "@react-native/eslint-config": "0.85.0",
    "@react-native/jest-preset": "0.85.0",
    "@release-it/conventional-changelog": "^10.0.5",
    "@testing-library/react-hooks": "^8.0.1",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.14",
    "@types/react-test-renderer": "^19",
    "commitlint": "^20.4.2",
    "del-cli": "^7.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.2.0",
    "jest-junit": "^16.0.0",
    "lefthook": "^2.1.1",
    "prettier": "^3.8.1",
    "react": "19.2.3",
    "react-native": "0.85.0",
    "react-native-builder-bob": "^0.40.18",
    "react-native-webview": "^13.16.0",
    "react-test-renderer": "19.2.3",
    "release-it": "^19.2.4",
    "turbo": "^2.8.11",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.73.0",
    "react-native-webview": ">=13.0.0"
  },
  "workspaces": [
    "example"
  ],
  "packageManager": "yarn@4.12.0",
  "codegenConfig": {
    "name": "BoltReactNativeSdkSpec",
    "type": "all",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "com.boltreactnativesdk"
    },
    "ios": {
      "componentProvider": {
        "BoltApplePayButton": "BoltApplePayButtonComponentView",
        "BoltCreditCardField": "BoltCreditCardFieldComponentView"
      }
    }
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/api-logs": "^0.213.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.213.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/resources": "^2.6.0",
    "@opentelemetry/sdk-logs": "^0.213.0",
    "@opentelemetry/sdk-trace-base": "^2.6.0",
    "@opentelemetry/semantic-conventions": "^1.40.0"
  }
}
