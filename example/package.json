{
  "name": "bolt-react-native-sdk-example",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "node ../scripts/gen-bolt-config.js && react-native run-android",
    "ios": "node ../scripts/gen-bolt-config.js && react-native run-ios",
    "start": "node ../scripts/gen-bolt-config.js && react-native start",
    "build:android": "react-native build-android --extra-params \"--no-daemon --console=plain -PreactNativeArchitectures=arm64-v8a\"",
    "build:ios": "react-native build-ios --mode Debug"
  },
  "dependencies": {
    "react": "19.2.3",
    "react-native": "0.85.2",
    "react-native-get-random-values": "^2.0.0",
    "react-native-webview": "^13.16.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/runtime": "^7.29.2",
    "@react-native-community/cli": "20.1.3",
    "@react-native-community/cli-platform-android": "20.1.3",
    "@react-native-community/cli-platform-ios": "20.1.3",
    "@react-native/babel-preset": "0.85.2",
    "@react-native/metro-config": "0.85.2",
    "@react-native/typescript-config": "0.85.2",
    "@types/react": "^19.2.14",
    "react-native-builder-bob": "^0.41.0",
    "react-native-monorepo-config": "^0.3.3"
  },
  "engines": {
    "node": ">=20"
  }
}
